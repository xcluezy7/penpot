# Agent Bridge configuration
PORT=4401
HOST=0.0.0.0

# Penpot backend connection
PENPOT_BACKEND_URL=http://localhost:3448
PENPOT_WS_URL=ws://localhost:3448

# MCP plugin (for task execution on canvas)
MCP_PLUGIN_URL=http://localhost:4400

# Agent WebSocket port (OpenClaw agents connect here)
AGENT_WS_PORT=4402

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Shared auth token for agent connections
AGENT_AUTH_TOKEN=

# Connection limits
MAX_AGENT_SESSIONS=10
CONNECTION_TIMEOUT_MS=30000
